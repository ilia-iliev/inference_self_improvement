# Copy to .env (in this docker/ directory) and edit.

# Absolute path to the model directory. Mounted into containers via a disk-level
# volume (e.g. /mnt/hdd2:/mnt/hdd2) so the path resolves identically everywhere.
# Modality (text-only vs image/audio) is detected automatically from the model's
# config.json — no manual flag needed.
MODEL_PATH=/mnt/hdd2/your-org/your-model
