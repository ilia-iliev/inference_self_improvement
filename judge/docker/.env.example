# Copy to .env (in this docker/ directory) and edit.

# Absolute path on the host to your Hugging Face cache directory.
# Mounted read-only at /root/.cache/huggingface inside the container.
HF_CACHE_DIR=/home/you/.cache/huggingface

# HF repo id (or absolute path) that from_pretrained loads.
# Text-only target: google/gemma-3-1b-it
# Multimodal target: google/gemma-4-E2B (needs >=12 GB VRAM)
MODEL_PATH=google/gemma-3-1b-it

# 1 = text-only path (AutoTokenizer + AutoModelForCausalLM, only text prompts).
# 0 = multimodal path (AutoProcessor + AutoModelForImageTextToText, all modalities).
# Single source of truth — read by servers, inference, and prompt generator.
TEXT_ONLY=1
